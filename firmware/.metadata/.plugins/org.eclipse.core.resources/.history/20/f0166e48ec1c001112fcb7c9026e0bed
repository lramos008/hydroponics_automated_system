#ifndef RTC_H
#define RTC_H
/*Includes*/
#include <stdint.h>

/*Public enums*/
typedef enum{
	RTC_OK = 0,
	RTC_ERR_NULL,
	RTC_ERR_INVALID_MODE,
	RTC_ERR_INVALID_ALARM,
	RTC_ERR_TIMEOUT,
	RTC_ERR_BUS
}rtc_err_t;

typedef enum{
	RTC_ALARM1 = 0,
	RTC_ALARM2
}rtc_alarm_id_t;

typedef enum{
	RTC_ALARM_EVERY_SECOND,
	RTC_ALARM_EVERY_MINUTE,
	RTC_ALARM_MATCH_TIME,
	RTC_ALARM_MATCH_DATE_TIME,
	RTC_ALARM_MATCH_DAY_TIME
}rtc_alarm_mode_t;

/*Public structures*/
typedef struct{
	ds3231_t ds3231;

}rtc_t;

typedef struct{
	uint8_t seconds;
	uint8_t minutes;
	uint8_t hours;
	uint8_t day;
	uint8_t date;
	uint8_t month;
	uint16_t year;
}rtc_datetime_t;

typedef struct{
	rtc_alarm_mode_t mode;
	uint8_t seconds;
	uint8_t minutes;
	uint8_t hours;
	uint8_t dydt;
}rtc_alarm_config_t;

/*API functions*/
rtc_err_t rtc_set_datetime(rtc_t *rtc, const rtc_datetime_t *dt);
rtc_err_t rtc_get_datetime(rtc_t *rtc, rtc_datetime_t *dt);
rtc_err_t rtc_set_alarm(rtc_t *rtc, rtc_alarm_config_t *config);


#endif/*RTC_H*/
