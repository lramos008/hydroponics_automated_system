/*Includes*/
#include "ds3231.h"
#include "stm32f4xx_hal.h"
#include <stdbool.h>

/*Defines / Macros*/
//Register addresses
#define DS3231_DATETIME_REG_ADDR 0x00
#define DS3231_ALARM1_REG_ADDR	 0x07
#define DS3231_ALARM2_REG_ADDR	 0x0B
#define DS3231_CONTROL_REG_ADDR	 0x0E
#define DS3231_STATUS_REG_ADDR	 0x0F

//Register sizes
#define DS3231_DATETIME_REG_SIZE 7
#define DS3231_ALARM1_REG_SIZE	 4
#define DS3231_ALARM2_REG_SIZE   3
#define DS3231_CONTROL_REG_SIZE  1
#define DS3231_STATUS_REG_SIZE	 1

/*Private functions*/
static ds3231_err_t serialize_alarm1_data(ds3231_alarm_mode_t mode, const ds3231_alarm_config_t *config, uint8_t *buffer){
	//Fill buffer with default behaviour (once a second)
	buffer[0] = config->seconds | (1 << 7);
	buffer[1] = config->minutes | (1 << 7);
	buffer[2] = (config->hours  | (1 << 7)) & ~(1 << 6);					//Set in 24 hours mode
	buffer[4] = config->dydt 	| (1 << 7);

	//Check alarm mode
	ds3231_err_t err = DS3231_OK;
	switch(mode){
	case DS3231_ALARM_ONCE_A_SEC:
		/*Do nothing, executes alarm once per second*/
		break;

	case DS3231_ALARM_SEC_MATCH:
		buffer[0] &= ~(1 << 7);
		break;

	case DS3231_ALARM_MIN_SEC_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		break;

	case DS3231_ALARM_HR_MIN_SEC_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		buffer[2] &= ~(1 << 7);
		break;

	case DS3231_ALARM_DT_HR_MIN_SEC_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		buffer[2] &= ~(1 << 7);
		buffer[3] &= ~(1 << 7);

		//Set date mode for this alarm
		buffer[3] &= ~(1 << 6);
		break;

	case DS3231_ALARM_DY_HR_MIN_SEC_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		buffer[2] &= ~(1 << 7);
		buffer[3] &= ~(1 << 7);

		//Set day mode for this alarm
		buffer[3] |= (1 << 6);
		break;

	default:
		err = DS3231_ERR_INVALID_MODE;
		break;
	}
	return err;
}

static ds3231_err_t serialize_alarm2_data(ds3231_alarm_mode_t mode, const ds3231_alarm_config_t *config, uint8_t *buffer){
	//Fill buffer with default behaviour (once per minute)
	buffer[0] = config->minutes | (1 << 7);
	buffer[1] = (config->hours  | (1 << 7)) & ~(1 << 6);					//Set in 24 hours mode
	buffer[2] = config->dydt 	| (1 << 7);

	//Check alarm mode
	ds3231_err_t err = DS3231_OK;
	switch(mode){
	case DS3231_ALARM_ONCE_PER_MIN:
		/*Do nothing, executes alarm once per minute*/
		break;

	case DS3231_ALARM_MIN_MATCH:
		buffer[0] &= ~(1 << 7);
		break;

	case DS3231_ALARM_HR_MIN_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		break;

	case DS3231_ALARM_DT_HR_MIN_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		buffer[2] &= ~(1 << 7);

		//Set date mode for alarm
		buffer[2] &= ~(1 << 6);
		break;

	case DS3231_ALARM_DY_HR_MIN_MATCH:
		buffer[0] &= ~(1 << 7);
		buffer[1] &= ~(1 << 7);
		buffer[2] &= ~(1 << 7);

		//Set date mode for alarm
		buffer[2] |= (1 << 6);
		break;

	default:
		err = DS3231_ERR_INVALID_MODE;
		break;
	}
	return err;
}

static ds3231_err_t ds3231_disable_en32kHz(ds3231_t *dev){
	//Sanity check
	if(!dev || !dev->hi2c){
		return DS3231_ERR_NULL;
	}

	//Read status register
	uint8_t status_reg;
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_STATUS_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			&status_reg, DS3231_STATUS_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	//Disable 32 kHz output
	status_reg &= ~(1 << 3);

	//Write into status register
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_STATUS_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			&status_reg, DS3231_STATUS_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}
	return DS3231_OK;
}

/*API functions*/
ds3231_err_t ds3231_init(ds3231_t *dev, I2C_HandleTypeDef *hi2c, uint8_t dev_address){
	//Sanity check
	if(!dev || !hi2c){
		return DS3231_ERR_NULL;
	}

	//Init DS3231 handle
	dev->hi2c = hi2c;
	dev->dev_address = dev_address;
	HAL_Delay(1000);

	//Disable 32 kHz output
	ds3231_err_t err;
	err = ds3231_disable_en32kHz(dev);
	if(err != DS3231_OK) return err;

	//Disable interrupts
	err = ds3231_disable_alarm(dev, DS3231_ALARM1);
	if(err != DS3231_OK) return err;

	err = ds3231_disable_alarm(dev, DS3231_ALARM2);
	if(err != DS3231_OK) return err;

	//Clear interrupt flags
	err = ds3231_clear_alarm_flag(dev, DS3231_ALARM1);
	if(err != DS3231_OK) return err;

	err = ds3231_clear_alarm_flag(dev, DS3231_ALARM2);
	if(err != DS3231_OK) return err;

	return DS3231_OK;
}


ds3231_err_t ds3231_set_datetime(ds3231_t *dev, const ds3231_datetime_t *dt){
	//Sanity check
	if(!dev || !dev->hi2c || !dt){
		return DS3231_ERR_NULL;
	}

	//Serialize datetime
	uint8_t buffer[DS3231_DATETIME_REG_SIZE] = {0};
	buffer[0] = dt->seconds;
	buffer[1] = dt->minutes;
	buffer[2] = dt->hours;
	buffer[3] = dt->day;
	buffer[4] = dt->date;
	buffer[5] = dt->month;
	buffer[6] = dt->year;

	//Write new datetime into DS3231 register
	HAL_StatusTypeDef status;

	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_DATETIME_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
							   buffer, DS3231_DATETIME_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}
	return DS3231_OK;
}

ds3231_err_t ds3231_get_datetime(ds3231_t *dev, ds3231_datetime_t *dt){
	//Sanity check
	if(!dev || !dev->hi2c || !dt){
		return DS3231_ERR_NULL;
	}

	//Read DS3231 register
	HAL_StatusTypeDef status;
	uint8_t buffer[DS3231_DATETIME_REG_SIZE];

	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_DATETIME_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
							  buffer, DS3231_DATETIME_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	//De-serialize data
	dt->seconds = buffer[0];
	dt->minutes = buffer[1];
	dt->hours   = buffer[2];
	dt->day     = buffer[3];
	dt->date    = buffer[4];
	dt->month   = buffer[5];
	dt->year    = buffer[6];

	return DS3231_OK;
}

ds3231_err_t ds3231_set_alarm(ds3231_t *dev, ds3231_alarm_t alarm, ds3231_alarm_mode_t mode, const ds3231_alarm_config_t *config){
	//Sanity check
	if(!dev || !dev->hi2c || !config){
		return DS3231_ERR_NULL;
	}

	if(alarm != DS3231_ALARM1 && alarm != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Check alarm type
	ds3231_err_t err;
	uint8_t alarm_reg_address;
	uint16_t buffer_size;
	uint8_t buffer[DS3231_ALARM1_REG_SIZE];
	if(alarm == DS3231_ALARM1){
		//Serialize data
		err = serialize_alarm1_data(mode, config, buffer);
		if(err != DS3231_OK){
			return err;
		}

		//Set current buffer size and alarm reg address
		buffer_size = DS3231_ALARM1_REG_SIZE;
		alarm_reg_address = DS3231_ALARM1_REG_ADDR;
	}
	else{
		//Serialize data
		err = serialize_alarm2_data(mode, config, buffer);
		if(err != DS3231_OK){
			return err;
		}

		//Set current buffer size and alarm reg address
		buffer_size = DS3231_ALARM2_REG_SIZE;
		alarm_reg_address = DS3231_ALARM2_REG_ADDR;
	}

	//Write new alarm config into DS3231 register
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, (uint16_t)alarm_reg_address, I2C_MEMADD_SIZE_8BIT,
							   buffer, buffer_size, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}
	return DS3231_OK;
}

ds3231_err_t ds3231_enable_alarm(ds3231_t *dev, ds3231_alarm_t alarm){
	//Sanity check
	if(!dev || !dev->hi2c){
		return DS3231_ERR_NULL;
	}

	if(alarm != DS3231_ALARM1 && alarm != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Read control register
	uint8_t control_reg;
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
							  &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	//Enable alarm interrupt bits
	control_reg |= (1 << 2);						//Enable INTCN
	if(alarm == DS3231_ALARM1){
		control_reg |= (1 << 0);					//Enable alarm 1
	}
	else{
		control_reg |= (1 << 1);					//Enable alarm 2
	}

	//Write into control register
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			                   &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}
	return DS3231_OK;
}

ds3231_err_t ds3231_disable_alarm(ds3231_t *dev, ds3231_alarm_t alarm){
	//Sanity check
	if(!dev || !dev->hi2c){
		return DS3231_ERR_NULL;
	}

	if(alarm != DS3231_ALARM1 && alarm != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Read control register
	uint8_t control_reg;
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
							  &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	//Get current alarms running
	bool alarm1_en = control_reg & (1 << 0);
	bool alarm2_en = (control_reg & (1 << 1)) >> 1;
	bool intcn_bit = (control_reg & (1 << 2)) >> 2;

	//Disable alarm interrupt bits
	if(!intcn_bit && !alarm1_en && !alarm2_en){					//Everything is already disabled
		return DS3231_OK;
	}

	if(alarm == DS3231_ALARM1){
		control_reg &= ~(1 << 0);						//Disable alarm 1
		alarm1_en = false;
	}
	else{
		control_reg &= ~(1 << 1);						//Disable alarm 2
		alarm2_en = false;
	}

	//Check if there is another alarm running
	if(!alarm1_en && !alarm2_en){
		control_reg &= ~(1 << 2);						//Disable INTCN bit
	}

	//Write into control register
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			                   &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
								  &control_reg, DS3231_CONTROL_REG_SIZE, 500);
		if(status != HAL_OK){
			if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
			else return DS3231_ERR_BUS;
		}
	return DS3231_OK;
}

ds3231_err_t ds3231_clear_alarm_flag(ds3231_t *dev, ds3231_alarm_t alarm){
	//Sanity check
	if(!dev || !dev->hi2c){
		return DS3231_ERR_NULL;
	}

	if(alarm != DS3231_ALARM1 && alarm != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Read status register
	uint8_t status_reg;
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_STATUS_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			&status_reg, DS3231_STATUS_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	//Clear interrupt flag
	if(alarm == DS3231_ALARM1){
		status_reg &= ~(1 << 0);					//Clear alarm1 interrupt flag
	}
	else{
		status_reg &= ~(1 << 1);					//Clear alarm2 interrupt flag
	}

	//Write into status register
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_STATUS_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			&status_reg, DS3231_STATUS_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}
	return DS3231_OK;
}

ds3231_err_t ds3231_read_status(ds3231_t *dev, uint8_t *status_reg){
	//Sanity check
	if(!dev || !dev->hi2c || !status_reg){
		return DS3231_ERR_NULL;
	}

	//Read status register
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_STATUS_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			status_reg, DS3231_STATUS_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_I2C_COMM;
	}
	return DS3231_OK;
}
