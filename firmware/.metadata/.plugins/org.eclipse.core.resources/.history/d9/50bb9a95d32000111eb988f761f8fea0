ds3231_err_t ds3231_enable_alarm(ds3231_t *dev, ds3231_alarm_id_t alarm_id){
	//Sanity check
	if(!dev || !dev->hi2c){
		return DS3231_ERR_NULL;
	}

	if(alarm_id != DS3231_ALARM1 && alarm_id != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Read control register
	uint8_t control_reg;
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
							  &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	//Enable alarm interrupt bits
	if(alarm_id == DS3231_ALARM1){
		control_reg |= (1 << 0);					//Enable alarm 1
	}
	else{
		control_reg |= (1 << 1);					//Enable alarm 2
	}

	//Write into control register
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			                   &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}
	return DS3231_OK;
}

ds3231_err_t ds3231_disable_alarm(ds3231_t *dev, ds3231_alarm_id_t alarm_id){
	//Sanity check
	if(!dev || !dev->hi2c){
		return DS3231_ERR_NULL;
	}

	if(alarm_id != DS3231_ALARM1 && alarm_id != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Read control register
	uint8_t control_reg;
	HAL_StatusTypeDef status;
	status = HAL_I2C_Mem_Read(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
							  &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	if(alarm_id == DS3231_ALARM1){
		control_reg &= ~(1 << 0);						//Disable alarm 1
	}
	else{
		control_reg &= ~(1 << 1);						//Disable alarm 2
	}

	//Write into control register
	status = HAL_I2C_Mem_Write(dev->hi2c, (uint16_t)dev->dev_address, DS3231_CONTROL_REG_ADDR, I2C_MEMADD_SIZE_8BIT,
			                   &control_reg, DS3231_CONTROL_REG_SIZE, 500);
	if(status != HAL_OK){
		if(status == HAL_TIMEOUT) return DS3231_ERR_TIMEOUT;
		else return DS3231_ERR_BUS;
	}

	return DS3231_OK;
}

