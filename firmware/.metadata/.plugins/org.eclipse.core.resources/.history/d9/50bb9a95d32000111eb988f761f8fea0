ds3231_err_t ds3231_check_alarm_triggered(ds3231_t *dev, ds3231_alarm_id_t alarm_id, bool *is_triggered){
	//Sanity check
	if(!dev || !dev->hi2c || !is_triggered){
		return DS3231_ERR_NULL;
	}

	if(alarm_id != DS3231_ALARM1 && alarm_id != DS3231_ALARM2){
		return DS3231_ERR_INVALID_ALARM;
	}

	//Read status register
	uint8_t status_reg;
	bool alarm_flag_bit;
	ds3231_err_t err = ds3231_read_status(dev, &status_reg);
	if(err != DS3231_OK){
		return err;
	}

	//Check alarm flag
	if(alarm_id == DS3231_ALARM1){
		alarm_flag_bit = (bool)(status_reg & (1 << 0));
	}
	else{
		alarm_flag_bit = (bool)(status_reg & (1 << 1));
	}

	*is_triggered = alarm_flag_bit;

	return DS3231_OK;
}

